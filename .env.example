# ============================================================
# AutonomDS — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME=AutonomDS
APP_ENV=development          # development | production
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── API Server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Streamlit Frontend ──────────────────────────────────────
STREAMLIT_PORT=8501
STREAMLIT_API_URL=http://localhost:8000

# ── LLM Configuration ───────────────────────────────────────
# Primary: Ollama (local, free, no rate limits)
LLM_PROVIDER=ollama          # ollama | huggingface | auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT=120

# Fallback: HuggingFace Inference API (free tier)
# Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Code generation model (DeepSeek Coder preferred)
CODE_LLM_MODEL=deepseek-coder:6.7b-instruct

# ── Embeddings ──────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu          # cpu | cuda | mps

# ── Vector Database (ChromaDB) ───────────────────────────────
CHROMA_PERSIST_DIR=./experiments/chroma_db
CHROMA_COLLECTION_NAME=experiment_memory

# ── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///./experiments/mlflow.db
MLFLOW_EXPERIMENT_NAME=autonomds-experiments
MLFLOW_ARTIFACT_ROOT=./experiments/mlflow_artifacts

# ── Redis / Celery ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Database (SQLite) ────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./experiments/autonomds.db

# ── Storage ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
REPORTS_DIR=./experiments/reports
MAX_UPLOAD_SIZE_MB=200
ALLOWED_EXTENSIONS=csv,xlsx,xls,parquet,sqlite,db

# ── Kaggle ──────────────────────────────────────────────────
# Get from: https://www.kaggle.com/settings/account → Create API Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Training ────────────────────────────────────────────────
TRAINING_DEVICE=auto          # auto | cpu | cuda | mps
MAX_TRAINING_TIME_SECONDS=300
OPTUNA_N_TRIALS=30
CROSS_VAL_FOLDS=5

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | console
LOG_FILE=./logs/autonomds.log

# ── Security ────────────────────────────────────────────────
SANDBOX_TIMEOUT_SECONDS=30
MAX_CODE_LENGTH=10000
ENABLE_SANDBOXED_EXECUTION=true
