# Streamlit Cloud Secrets — Template
# =============================================
# In Streamlit Community Cloud:
#   App → Settings → Secrets → paste the content below
#   (with your real Render URL filled in)
#
# For local development, copy this file to:
#   app/frontend/.streamlit/secrets.toml
# and fill in the values.
#
# NEVER commit a secrets.toml with real values to GitHub!
# It is already in .gitignore.
# =============================================

# Your deployed Render API URL
# (get this after deploying to Render in Step 4)
API_BASE_URL = "https://autonomds-api-xxxx.onrender.com"
